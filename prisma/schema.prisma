generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id           String   @id @default(cuid())
  name         String
  email        String
  type         String   // "project-enquiry" | "careers" | "speak-to-team"
  reason       String?
  companyName  String?
  companyStage String?
  hearAboutUs  String?
  message      String
  createdAt    DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}
